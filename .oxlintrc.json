{
  "jsPlugins": ["./src/index.ts"],
  "rules": {
    "typescript/no-explicit-any": "error",
    "eslint/no-restricted-imports": [
      "error",
      {
        "paths": [
          {
            "name": "vitest",
            "importNames": ["it"],
            "message": "Do not import \"it()\" directly from vitest. Use \"test()\" instead."
          }
        ]
      }
    ],
    "eslint/eqeqeq": "error",
    "typescript/consistent-type-imports": "error",
    "eslint/curly": "error",
    "crescware-no-inline-expected/no-inline-expected": "error"
  },
  "ignorePatterns": ["fixtures/cases/**", "fixtures/order-cases/**"]
}
